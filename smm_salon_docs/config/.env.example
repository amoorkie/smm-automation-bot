TG_BOT_TOKEN=
OPENROUTER_API_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

OWNER_CHAT_ID=
BOT_DISABLED=false
INTERNAL_WORKER_DISPATCH_ENABLED=false
TOPIC_SOURCE_STATUS_MUTATIONS_ENABLED=false

APP_TIMEZONE=Europe/Moscow
IMAGE_MODEL_ID=google/gemini-3.1-flash-image-preview
TEXT_MODEL_ID=openai/gpt-5.4

# Optional for local Fastify run; on Vercel the service derives the base URL from VERCEL_URL.
WEBHOOK_BASE_URL=https://example.com
PORT=3000

# Optional VK wall publishing after Telegram preview confirmation.
# VK_ACCESS_TOKEN uploads photos; VK_COMMUNITY_ACCESS_TOKEN can be used for wall.post fallback.
VK_ACCESS_TOKEN=
VK_COMMUNITY_ACCESS_TOKEN=
VK_GROUP_ID=
VK_PUBLISH_ENABLED=false
VK_CLIENT_ID=
VK_CLIENT_SECRET=
VK_OAUTH_REDIRECT_URI=https://example.com/api/vk/oauth/callback
VK_OAUTH_SCOPE=photos,wall

# Contact block is not an env var. Store it in prompt_templates.contact_block.
